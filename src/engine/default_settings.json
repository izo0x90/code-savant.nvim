{
  "socket_path": "~/.cache/code_savant/engine.sock",
  "model": "gemini-3.5-flash",
  "small_model": null,
  "context_filenames": ["GEMINI.md"],
  "global_context_dir": "~/.gemini",
  "session_storage_dir": ".code_savant/sessions",
  "system_agents_dir": "prompts/agents",
  "agent_extensions": [".agent.yaml", ".agent.yml", ".md"],
  "requires_approval": true,
  "strategy_config": {
    "default": {
      "compression_threshold": 0.60,
      "dir_cutoff_limit": 200,
      "ignored_directories": [
        ".git",
        "node_modules",
        ".venv",
        "__pycache__",
        "dist",
        "build",
        ".pytest_cache",
        ".replica_sessions",
        ".code_savant"
      ]
    }
  },
  "providers": {
    "google": {
      "api_key_env_var": "GEMINI_API_KEY",
      "base_url": null,
      "options": {}
    },
    "anthropic": {
      "api_key_env_var": "ANTHROPIC_API_KEY",
      "base_url": null,
      "options": {}
    },
    "openai": {
      "api_key_env_var": "OPENAI_API_KEY",
      "base_url": null,
      "options": {}
    }
  }
}
